# Supabase Configuration
#
# This project uses different databases for development and production:
# - Development: Local Supabase (via Docker)
# - Production: Supabase Cloud
#
# Environment files are loaded automatically by Vite based on build mode:
# - npm run dev    -> .env.development (local Supabase)
# - npm run build  -> .env.production (cloud Supabase)

# For production (.env.production):
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-production-anon-key

# For local development (.env.development uses these defaults):
# VITE_SUPABASE_URL=http://127.0.0.1:54321
# VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZS1kZW1vIiwicm9sZSI6ImFub24iLCJleHAiOjE5ODM4MTI5OTZ9.CRXP1A7WOeoJeXxjNni43kdQwgnWNReilDMblYTn_I0
